# =============================================================================
# PPG WEB UI (webui/app.py)
# Defaults: webui/config.json ("host", "port"). Uncomment or change to override:
# =============================================================================
PPG_WEB_HOST=127.0.0.1
PPG_WEB_PORT=5959

# =============================================================================
# PLEX SERVER CONFIGURATION (All Scripts)
# =============================================================================
PLEX_URL=http://SERVERIP:32400  # Replace with your Plex server URL
PLEX_TOKEN=YOURTOKENHERE  # Replace with your Plex token
# Library title as shown in Plex (Web UI uses this for "Fetch genres")
PLEX_MUSIC_SECTION=Music

# =============================================================================
# SHARED CONFIGURATION (All Scripts)
# =============================================================================
SONGS_PER_PLAYLIST=50  # Number of songs per playlist
MAX_ARTIST_PERCENTAGE=0.3  # Maximum percentage of songs per artist (0.3 = 30%)
MAX_LIKED_ARTISTS_PERCENTAGE=0.8  # Maximum percentage of songs from liked artists (0.8 = 80%)
MIN_VARIETY_PERCENTAGE=0.1  # Minimum percentage of songs from other artists for variety (0.1 = 10%)
LIKED_ARTISTS_CACHE_FILE=liked_artists_cache.json  # File to cache liked artists
CACHE_DAYS=7  # Number of days to keep liked artists cache (7 = 1 week)

# Minimum pool size as a fraction of SONGS_PER_PLAYLIST (e.g. 0.75 = need 75% of target count in the pool).
# One value for all generator scripts (Daily, Weekly, Genres, Moods, Liked Artists). When set, per-script
# DAILY_MIN_SONGS_REQUIRED / WEEKLY_… / GENRES_… / MOODS_MIN_TRACK_PERCENT / LIKED_ARTISTS_… are not required.
# Leave unset to use those per-script variables instead (see sections below).
# PPG_MIN_SONGS_REQUIRED_PERCENT=0.75

# Playlist Quality & Variety Settings
MIN_SONG_DURATION_SECONDS=90  # Minimum song duration in seconds (90 = 1.5 minutes)
MAX_SONGS_PER_ALBUM=1  # Maximum number of songs from the same album (1 = no duplicates)
PREVENT_CONSECUTIVE_ARTISTS=true  # Prevent same artist from appearing consecutively (true/false)
MOOD_GROUPING_ENABLED=true  # Group songs by mood for better flow - picks a random mood and groups matching songs (true/false)

# Optional: exclude tracks by title / album (Python regex, case-insensitive). Empty = disabled.
# Example (skits, many live cuts, demos): \b(skit|live(\s+from|\s+at|\s+in)?|demo(\s+version)?|acoustic session|interlude)\b
SKIP_SONG_TITLE_REGEX=
SKIP_ALBUM_TITLE_REGEX=

# Logging Configuration
LOG_LEVEL=INFO  # Log level: DEBUG, INFO, WARNING, ERROR. DEBUG shows everything, INFO shows normal operations, WARNING shows only warnings/errors

# After this many consecutive failures for the same playlist title (without a successful build in between),
# the playlist is flagged in webui/data/playlist_chronic_failures.json and under Statistics → Playlists needing attention.
# PPG_CHRONIC_FAILURE_THRESHOLD=3

# Optional: Telegram summary when a script run finishes (CLI, cron, or web UI subprocess).
# Leave token/chat blank to disable. TELEGRAM_NOTIFICATIONS=false turns off sends without removing credentials.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_NOTIFICATIONS=true

# =============================================================================
# PPG-Daily.py CONFIGURATION
# =============================================================================
DAILY_PLAYLIST_COUNT=7  # Number of daily playlists to generate
DAILY_MIN_SONGS_REQUIRED=0.8  # Minimum percentage of songs required (0.8 = 80%)
# Pools of genres (same JSON shape). Daily/Weekly pick ONE pool at random per playlist — no "Name Mix" playlists.
DAILY_GENRE_GROUPS_FILE=daily_weekly_genre_pools.json
DAILY_LOG_FILE=dailylog.txt  # File to store used genre groups
DAILY_MAX_LOG_ENTRIES=50  # Maximum number of entries in daily log

# =============================================================================
# PPG-Weekly.py CONFIGURATION
# =============================================================================
WEEKLY_PLAYLIST_COUNT=7  # Number of weekly playlists to generate
WEEKLY_MIN_SONGS_REQUIRED=0.8  # Minimum percentage of songs required (0.8 = 80%)
WEEKLY_GENRE_GROUPS_FILE=daily_weekly_genre_pools.json
WEEKLY_LOG_FILE=weeklylog.txt  # File to store used genre groups
WEEKLY_MAX_LOG_ENTRIES=50  # Maximum number of entries in weekly log

# =============================================================================
# PPG-Genres.py & PPG-Moods.py CONFIGURATION
# =============================================================================
GENRES_MIN_SONGS_REQUIRED=0.5  # Minimum percentage of songs required for genres (0.5 = 50%)
MOODS_MIN_TRACK_PERCENT=0.8  # Minimum percentage of tracks required for moods (0.8 = 80%)
# One Plex playlist per top-level key: "{key} Mix" (PPG-Genres). Same JSON shape as pools, different script.
GENRE_MIXES_FILE=named_genre_mix_playlists.json
MOOD_GROUPS_FILE=mood_groups.json  # Path to mood groups JSON file
GENRES_AUTO_REPLACE_POSTERS=false  # Automatically replace playlist posters from Spotify (true/false)
MOODS_AUTO_REPLACE_POSTERS=false

# =============================================================================
# PPG-LikedArtists.py CONFIGURATION
# =============================================================================

LIKED_ARTISTS_PLAYLIST_COUNT=5  # Number of liked artist playlists to generate
LIKED_ARTISTS_MIN_SONGS_REQUIRED=0.8  # Minimum percentage of songs required (0.8 = 80%)
LIKED_ARTISTS_LOG_FILE=likedartistslog.txt  # File to store used artists
LIKED_ARTISTS_MAX_LOG_ENTRIES=50  # Maximum number of entries in liked artists log